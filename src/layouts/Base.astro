---
import '../styles/global.css';
const {
  title = "Y'TILIKAN — Ce n'est pas sorcier",
  description = "Y'TILIKAN est une communauté de partage qui vulgarise et rend accessible la technologie — et surtout l'IA — pour l'Afrique et sa diaspora.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="theme-color" content="#242E58" />
  </head>
  <body>
    <slot />

    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const el = e.target as HTMLElement;
                const delay = el.dataset.delay;
                if (delay) el.style.transitionDelay = delay + 'ms';
                el.classList.add('in');
                io.unobserve(el);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
