---
import { SITE } from '../data/site';

const CHANNEL = SITE.youtube.url;
const GITHUB = SITE.github;
const EMAIL = SITE.email;
const year = new Date().getFullYear();

const participate = [
  {
    kick: 'Regarder & apprendre',
    body: "Émissions, débats et formations gratuites, publiés régulièrement sur la chaîne.",
    cta: 'Voir la chaîne',
    href: CHANNEL,
    external: true,
  },
  {
    kick: 'Contribuer au code',
    body: "Nos projets sont ouverts. Issues, pull requests et datasets : les contributions sont les bienvenues.",
    cta: 'Ouvrir GitHub',
    href: GITHUB,
    external: true,
  },
  {
    kick: 'Collaborer',
    body: "Intervenant, invité, partenaire ou école : écris-nous pour construire quelque chose ensemble.",
    cta: 'Nous écrire',
    href: EMAIL,
    external: false,
  },
];

const footLinks = [
  { href: '#essence', label: 'Essence' },
  { href: '#participer', label: 'Participer' },
  { href: '#emissions', label: 'Émissions' },
  { href: '#programmes', label: 'Programmes' },
  { href: '#projets', label: 'Projets' },
  { href: '#equipe', label: 'Équipe' },
  { href: '#faq', label: 'FAQ' },
];
---
<section class="contact" id="contact" aria-labelledby="contact-title">
  <svg class="contact__pattern" aria-hidden="true"><rect width="100%" height="100%" fill="url(#maskpat)"/></svg>
  <div class="wrap contact__inner">
    <img src="/logo-white.jpg" alt="" class="contact__logo reveal" width="76" height="76" loading="lazy" decoding="async" />
    <h2 class="contact__title reveal" id="contact-title" data-delay="80">
      Construisons une Afrique qui comprend<br />
      la technologie <em>parce qu'on y participe pleinement.</em>
    </h2>
    <p class="contact__lead reveal" data-delay="160">
      Pas de formulaire d'inscription, pas de promesse en l'air : on avance
      avec ceux qui participent. Trois façons concrètes de le faire, dès aujourd'hui.
    </p>

    <div class="participate reveal">
      {participate.map((p) => (
        <a
          class="pt card-hover"
          href={p.href}
          target={p.external ? '_blank' : undefined}
          rel={p.external ? 'noopener noreferrer' : undefined}
        >
          <span class="pt__kick">{p.kick}</span>
          <p class="pt__body">{p.body}</p>
          <span class="pt__cta">{p.cta}</span>
        </a>
      ))}
    </div>

    <div class="cform-block reveal">
      <h3 class="cform-block__title">Une question, une idée ? Écris-nous.</h3>
      <p class="cform-block__sub">On répond à chaque message. Réponse sous quelques jours.</p>

      <form class="cform" id="contact-form" data-key={SITE.web3formsKey}>
        <input type="hidden" name="access_key" value={SITE.web3formsKey} />
        <input type="hidden" name="from_name" value="Formulaire Y'TILIKAN" />
        <input type="checkbox" name="botcheck" class="cform__hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="cform__grid">
          <div class="cform__field">
            <label for="cf-name">Nom</label>
            <input id="cf-name" name="name" type="text" required autocomplete="name" placeholder="Ton nom" />
          </div>
          <div class="cform__field">
            <label for="cf-email">Email</label>
            <input id="cf-email" name="email" type="email" required autocomplete="email" placeholder="toi@exemple.com" />
          </div>
        </div>

        <div class="cform__field">
          <label for="cf-subject">Sujet</label>
          <select id="cf-subject" name="subject" required>
            <option value="" disabled selected>Choisis un sujet</option>
            <option>Devenir invité ou intervenant</option>
            <option>Partenariat</option>
            <option>École ou institution</option>
            <option>Contribuer aux projets</option>
            <option>Autre</option>
          </select>
        </div>

        <div class="cform__field">
          <label for="cf-message">Message</label>
          <textarea id="cf-message" name="message" rows="4" required placeholder="Dis-nous tout…"></textarea>
        </div>

        <button type="submit" class="btn btn--gold cform__submit">Envoyer le message</button>
        <p class="cform__status" role="status" aria-live="polite"></p>
      </form>

      <p class="cform-block__fallback">
        Ou directement par email : <a href={EMAIL}>{SITE.emailAddress}</a>
      </p>
    </div>
  </div>
</section>

<footer class="foot">
  <div class="wrap foot__grid">
    <div class="foot__brand">
      <div class="foot__lock">
        <img src="/logo-white.jpg" alt="" class="foot__logo" width="52" height="52" loading="lazy" decoding="async" />
        <span class="foot__wm">Y'TILIKAN</span>
      </div>
      <p class="foot__desc">Communauté de vulgarisation de l'IA pour l'Afrique francophone et sa diaspora. Formations, émissions et outils open-source, gratuits et en français.</p>
    </div>
    <nav class="foot__nav" aria-label="Liens du pied de page">
      {footLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={CHANNEL} target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="mailto:contact@ytilikan.com">Contact</a>
    </nav>
  </div>
  <div class="wrap foot__row">
    <span class="foot__meta">© {year} Y'TILIKAN · Tous droits réservés</span>
    <span class="foot__meta foot__meta--gold">La connaissance, c'est le pouvoir.</span>
  </div>
</footer>

<style>
  .contact {
    background: var(--indigo);
    color: var(--ivoire);
    position: relative;
    overflow: hidden;
    padding: 110px 0;
    text-align: center;
  }
  .contact__pattern { position: absolute; inset: 0; opacity: .08; pointer-events: none; }
  .contact__inner { position: relative; z-index: 2; max-width: 760px; margin: 0 auto; }
  .contact__logo { width: 76px; height: 76px; border-radius: 12px; object-fit: contain; margin: 0 auto 28px; display: block; }
  .contact__title {
    font-family: var(--display); font-weight: 800;
    font-size: clamp(1.9rem, 4.4vw, 3rem);
    letter-spacing: -.02em; line-height: 1.05; margin-bottom: 22px;
  }
  .contact__title em { font-style: normal; color: var(--ocre); }
  .contact__lead { font-size: 1.12rem; color: var(--on-dark-muted); max-width: 56ch; margin: 0 auto 44px; }
  .contact__cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  .participate {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-sm);
    text-align: left;
  }
  .pt {
    display: flex;
    flex-direction: column;
    background: rgba(250, 249, 246, .05);
    border: 1px solid rgba(250, 249, 246, .12);
    border-radius: var(--r-md);
    padding: 24px 22px;
  }
  .pt__kick {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--on-dark);
    margin-bottom: 10px;
  }
  .pt__body { color: rgba(250, 249, 246, .62); font-size: .9rem; line-height: 1.55; flex: 1; margin-bottom: 16px; }
  .pt__cta {
    font-family: var(--mono);
    font-size: .72rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ocre);
    transition: gap .2s;
  }
  .pt:hover .pt__cta { color: var(--orange-clair); }

  @media (max-width: 760px) {
    .participate { grid-template-columns: 1fr; }
  }

  /* —— Formulaire de contact —— */
  .cform-block {
    margin-top: var(--sp-xl);
    max-width: 620px;
    margin-inline: auto;
    text-align: left;
  }
  .cform-block__title {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    letter-spacing: -.02em;
    text-align: center;
    margin-bottom: 8px;
  }
  .cform-block__sub {
    text-align: center;
    color: var(--on-dark-muted);
    font-size: .95rem;
    margin-bottom: var(--sp-lg);
  }

  .cform { display: flex; flex-direction: column; gap: 18px; }
  .cform__hp { position: absolute; left: -9999px; opacity: 0; height: 0; width: 0; }
  .cform__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }

  .cform__field { display: flex; flex-direction: column; gap: 8px; }
  .cform__field label {
    font-family: var(--mono);
    font-size: .66rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--on-dark-muted);
  }
  .cform__field input,
  .cform__field select,
  .cform__field textarea {
    font-family: var(--body);
    font-size: .95rem;
    color: var(--ivoire);
    background: rgba(250, 249, 246, .05);
    border: 1px solid rgba(250, 249, 246, .16);
    border-radius: var(--r-md);
    padding: 13px 15px;
    transition: border-color .2s, background .2s;
  }
  .cform__field textarea { resize: vertical; min-height: 110px; }
  .cform__field input::placeholder,
  .cform__field textarea::placeholder { color: rgba(250, 249, 246, .38); }
  .cform__field select { appearance: none; cursor: pointer; }
  .cform__field select option { color: #1a1a1a; }
  .cform__field input:focus,
  .cform__field select:focus,
  .cform__field textarea:focus {
    outline: none;
    border-color: var(--ocre);
    background: rgba(250, 249, 246, .08);
  }

  .cform__submit { align-self: flex-start; margin-top: 4px; }

  .cform__status {
    font-size: .9rem;
    line-height: 1.5;
    min-height: 1.2em;
  }
  .cform__status.is-success { color: var(--orange-clair); }
  .cform__status.is-error { color: #ff8a80; }

  .cform-block__fallback {
    text-align: center;
    margin-top: 20px;
    font-size: .9rem;
    color: var(--on-dark-muted);
  }
  .cform-block__fallback a { color: var(--ocre); border-bottom: 1px solid transparent; transition: border-color .2s; }
  .cform-block__fallback a:hover { border-bottom-color: var(--ocre); }

  @media (max-width: 560px) {
    .cform__grid { grid-template-columns: 1fr; }
  }

  .foot { background: var(--encre); color: var(--ivoire); padding: 70px 0 40px; }
  .foot__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
    margin-bottom: 40px;
    align-items: start;
  }
  .foot__lock { display: flex; align-items: center; gap: 18px; margin-bottom: 16px; }
  .foot__logo { width: 52px; height: 52px; border-radius: 8px; object-fit: contain; }
  .foot__wm { font-family: var(--display); font-weight: 800; font-size: 1.7rem; }
  .foot__desc { color: rgba(250,249,246,.6); max-width: 46ch; font-size: .95rem; line-height: 1.55; }
  .foot__nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
  }
  .foot__nav a {
    font-size: .9rem;
    color: rgba(250,249,246,.6);
    transition: color .2s;
  }
  .foot__nav a:hover { color: var(--ocre); }
  .foot__row { display: flex; justify-content: space-between; align-items: flex-end; gap: 30px; flex-wrap: wrap; padding-top: 24px; border-top: 1px solid rgba(250,249,246,.12); }
  .foot__meta { font-family: var(--mono); font-size: .72rem; letter-spacing: .1em; color: rgba(250,249,246,.5); text-transform: uppercase; }
  .foot__meta--gold { color: var(--ocre); }

  @media (max-width: 860px) {
    .foot__grid { grid-template-columns: 1fr; gap: 32px; }
    .foot__nav { flex-flow: row wrap; gap: 12px 20px; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const status = form.querySelector('.cform__status') as HTMLElement | null;
    const submit = form.querySelector('.cform__submit') as HTMLButtonElement | null;
    const key = form.dataset.key ?? '';

    const setStatus = (msg: string, state: '' | 'is-success' | 'is-error') => {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove('is-success', 'is-error');
      if (state) status.classList.add(state);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!key || key === 'YOUR_WEB3FORMS_ACCESS_KEY') {
        setStatus("Le formulaire n'est pas encore activé. Écris-nous par email en attendant.", 'is-error');
        return;
      }

      const data = Object.fromEntries(new FormData(form).entries());
      if (submit) { submit.disabled = true; submit.textContent = 'Envoi…'; }
      setStatus('', '');

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();
        if (res.ok && result.success) {
          form.reset();
          setStatus('Message envoyé, merci. On revient vers toi rapidement.', 'is-success');
        } else {
          setStatus("L'envoi a échoué. Réessaie ou écris-nous par email.", 'is-error');
        }
      } catch {
        setStatus("Problème de connexion. Réessaie ou écris-nous par email.", 'is-error');
      } finally {
        if (submit) { submit.disabled = false; submit.textContent = 'Envoyer le message'; }
      }
    });
  }
</script>
