---
const CHANNEL = 'https://www.youtube.com/@YTILIKAN';
const GITHUB = 'https://github.com/YTILIKAN';
const EMAIL = 'mailto:contact@ytilikan.com';
const year = new Date().getFullYear();

const participate = [
  {
    kick: 'Regarder & apprendre',
    body: "Émissions, débats et formations gratuites, publiés régulièrement sur la chaîne.",
    cta: 'Voir la chaîne',
    href: CHANNEL,
    external: true,
  },
  {
    kick: 'Contribuer au code',
    body: "Nos projets sont ouverts. Issues, pull requests et datasets — les contributions sont les bienvenues.",
    cta: 'Ouvrir GitHub',
    href: GITHUB,
    external: true,
  },
  {
    kick: 'Collaborer',
    body: "Intervenant, invité, partenaire ou école : écris-nous pour construire quelque chose ensemble.",
    cta: 'Nous écrire',
    href: EMAIL,
    external: false,
  },
];

const footLinks = [
  { href: '#essence', label: 'Essence' },
  { href: '#emissions', label: 'Émissions' },
  { href: '#programmes', label: 'Programmes' },
  { href: '#projets', label: 'Projets' },
  { href: '#equipe', label: 'Équipe' },
];
---
<section class="contact" id="contact" aria-labelledby="contact-title">
  <svg class="contact__pattern" aria-hidden="true"><rect width="100%" height="100%" fill="url(#maskpat)"/></svg>
  <div class="wrap contact__inner">
    <img src="/logo-white.jpg" alt="" class="contact__logo reveal" width="76" height="76" loading="lazy" decoding="async" />
    <h2 class="contact__title reveal" id="contact-title" data-delay="80">
      Construisons une Afrique qui comprend<br />
      la technologie <em>parce qu'on y participe.</em>
    </h2>
    <p class="contact__lead reveal" data-delay="160">
      Pas de formulaire d'inscription, pas de promesse en l'air : Y'TILIKAN avance
      avec ceux qui participent. Trois façons concrètes de le faire, dès aujourd'hui.
    </p>

    <div class="participate reveal">
      {participate.map((p) => (
        <a
          class="pt card-hover"
          href={p.href}
          target={p.external ? '_blank' : undefined}
          rel={p.external ? 'noopener noreferrer' : undefined}
        >
          <span class="pt__kick">{p.kick}</span>
          <p class="pt__body">{p.body}</p>
          <span class="pt__cta">{p.cta} <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </div>
</section>

<footer class="foot">
  <div class="wrap foot__grid">
    <div class="foot__brand">
      <div class="foot__lock">
        <img src="/logo-white.jpg" alt="" class="foot__logo" width="52" height="52" loading="lazy" decoding="async" />
        <span class="foot__wm">Y'TILIKAN</span>
      </div>
      <p class="foot__desc">Communauté de vulgarisation de l'IA pour l'Afrique francophone et sa diaspora. Formations, émissions et outils open-source — gratuits et en français.</p>
    </div>
    <nav class="foot__nav" aria-label="Liens du pied de page">
      {footLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={CHANNEL} target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="mailto:contact@ytilikan.com">Contact</a>
    </nav>
  </div>
  <div class="wrap foot__row">
    <span class="foot__meta">© {year} Y'TILIKAN · Tous droits réservés</span>
    <span class="foot__meta foot__meta--gold">Ce n'est pas sorcier.</span>
  </div>
</footer>

<style>
  .contact {
    background: var(--indigo);
    color: var(--ivoire);
    position: relative;
    overflow: hidden;
    padding: 110px 0;
    text-align: center;
  }
  .contact__pattern { position: absolute; inset: 0; opacity: .08; pointer-events: none; }
  .contact__inner { position: relative; z-index: 2; max-width: 760px; margin: 0 auto; }
  .contact__logo { width: 76px; height: 76px; border-radius: 12px; object-fit: contain; margin: 0 auto 28px; display: block; }
  .contact__title {
    font-family: var(--display); font-weight: 800;
    font-size: clamp(1.9rem, 4.4vw, 3rem);
    letter-spacing: -.02em; line-height: 1.05; margin-bottom: 22px;
  }
  .contact__title em { font-style: normal; color: var(--ocre); }
  .contact__lead { font-size: 1.12rem; color: var(--on-dark-muted); max-width: 56ch; margin: 0 auto 44px; }
  .contact__cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  .participate {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-sm);
    text-align: left;
  }
  .pt {
    display: flex;
    flex-direction: column;
    background: rgba(250, 249, 246, .05);
    border: 1px solid rgba(250, 249, 246, .12);
    border-radius: var(--r-md);
    padding: 24px 22px;
  }
  .pt__kick {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--on-dark);
    margin-bottom: 10px;
  }
  .pt__body { color: rgba(250, 249, 246, .62); font-size: .9rem; line-height: 1.55; flex: 1; margin-bottom: 16px; }
  .pt__cta {
    font-family: var(--mono);
    font-size: .72rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ocre);
    transition: gap .2s;
  }
  .pt:hover .pt__cta { color: var(--orange-clair); }

  @media (max-width: 760px) {
    .participate { grid-template-columns: 1fr; }
  }

  .foot { background: var(--encre); color: var(--ivoire); padding: 70px 0 40px; }
  .foot__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
    margin-bottom: 40px;
    align-items: start;
  }
  .foot__lock { display: flex; align-items: center; gap: 18px; margin-bottom: 16px; }
  .foot__logo { width: 52px; height: 52px; border-radius: 8px; object-fit: contain; }
  .foot__wm { font-family: var(--display); font-weight: 800; font-size: 1.7rem; }
  .foot__desc { color: rgba(250,249,246,.6); max-width: 46ch; font-size: .95rem; line-height: 1.55; }
  .foot__nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
  }
  .foot__nav a {
    font-size: .9rem;
    color: rgba(250,249,246,.6);
    transition: color .2s;
  }
  .foot__nav a:hover { color: var(--ocre); }
  .foot__row { display: flex; justify-content: space-between; align-items: flex-end; gap: 30px; flex-wrap: wrap; padding-top: 24px; border-top: 1px solid rgba(250,249,246,.12); }
  .foot__meta { font-family: var(--mono); font-size: .72rem; letter-spacing: .1em; color: rgba(250,249,246,.5); text-transform: uppercase; }
  .foot__meta--gold { color: var(--ocre); }

  @media (max-width: 860px) {
    .foot__grid { grid-template-columns: 1fr; gap: 32px; }
    .foot__nav { flex-flow: row wrap; gap: 12px 20px; }
  }
</style>
