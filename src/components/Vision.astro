---
const ambitions = [
  {
    title: 'Éduquer sans exclure',
    body: 'Briser la fracture technologique avec des contenus compréhensibles, accessibles mais rigoureux — pour l\'étudiant, le professionnel, le parent ou le simple curieux.',
  },
  {
    title: "Représenter la voix de l'Afrique",
    body: "Trop souvent absente des débats mondiaux sur la tech, l'Afrique a une voix unique et des talents immenses. Nous en faisons une plateforme d'expression et de création.",
  },
  {
    title: 'Bâtir un écosystème durable',
    body: "Au-delà d'une chaîne : une communauté active, une plateforme de formation continue, un hub d'échange entre experts, jeunes talents et décideurs.",
  },
];

const valeurs = [
  { name: 'Résilience', desc: 'Persévérer pour bâtir un projet durable, s\'adapter, aller toujours plus loin.' },
  { name: 'Passion', desc: 'Comprendre, apprendre, transmettre. Un amour profond de la tech et du partage.' },
  { name: 'Innovation', desc: 'Créativité, expérimentation, solutions locales et pertinentes. Différent, utile, humain.' },
  { name: 'Engagement', desc: 'Informer avec honnêteté, former avec rigueur, dialoguer avec respect.' },
  { name: 'Culture', desc: 'Ancrés dans les cultures africaines, ouverts sur le monde, fiers de nos racines.' },
];
---
<section class="vision section-pad" id="vision">
  <div class="container">
    <div class="vision__split">
      <div class="vision__left">
        <p class="eyebrow reveal">Notre vision</p>
        <h2 class="vision__title reveal" data-delay="80">
          Un média de référence pour la tech africaine francophone.
        </h2>
        <p class="vision__lead reveal" data-delay="160">
          Le futur numérique ne doit pas être subi. Il doit être compris,
          préparé… et co-construit.
        </p>
      </div>

      <div class="vision__right">
        {ambitions.map((a, i) => (
          <div class="amb reveal" data-delay={String(i * 100)}>
            <div class="amb__dot" aria-hidden="true"></div>
            <div>
              <h3 class="amb__title">{a.title}</h3>
              <p class="amb__body">{a.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="valeurs">
      <p class="eyebrow reveal" style="margin-bottom:26px;">Nos valeurs</p>
      <div class="valeurs__grid">
        {valeurs.map((v, i) => (
          <article class="val reveal" data-delay={String(i * 70)}>
            <h4 class="val__name">{v.name}</h4>
            <p class="val__desc">{v.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .vision {
    background:
      linear-gradient(180deg, var(--yt-ink-950), var(--yt-ink-900));
  }
  .vision__split {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 64px;
    align-items: start;
    margin-bottom: 96px;
  }
  .vision__title {
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    margin: 20px 0 20px;
  }
  .vision__lead {
    color: var(--yt-accent);
    font-family: var(--yt-font-serif);
    font-style: italic;
    font-size: 1.24rem;
    line-height: 1.5;
  }

  .amb {
    display: flex;
    gap: 20px;
    padding: 22px 0;
    border-bottom: 1px solid var(--yt-border);
  }
  .amb:last-child { border-bottom: none; }
  .amb__dot {
    flex-shrink: 0;
    width: 10px; height: 10px;
    margin-top: 7px;
    border-radius: 50%;
    background: var(--yt-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--yt-amber-600) 18%, transparent);
  }
  .amb__title { font-size: 1.16rem; margin-bottom: 8px; }
  .amb__body { color: var(--yt-text-dim); font-size: 0.96rem; line-height: 1.65; }

  .valeurs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 16px;
  }
  .val {
    background: var(--yt-ink-800);
    border: 1px solid var(--yt-border);
    border-radius: var(--yt-radius);
    padding: 24px 22px;
    transition: transform 0.25s, border-color 0.25s;
  }
  .val:hover {
    transform: translateY(-4px);
    border-color: var(--yt-accent-deep);
  }
  .val__name {
    font-size: 1.05rem;
    color: var(--yt-accent);
    margin-bottom: 10px;
    letter-spacing: 0;
  }
  .val__desc { color: var(--yt-text-dim); font-size: 0.88rem; line-height: 1.6; }

  @media (max-width: 820px) {
    .vision__split { grid-template-columns: 1fr; gap: 40px; margin-bottom: 64px; }
  }
</style>
