---
const CHANNEL = 'https://www.youtube.com/@YTILIKAN';

const videos = [
  { kick: 'Formation', title: 'Formation : Vibe Coding avec l\'IA', meta: '1:35:04', id: '4zQ-YN_SvlU' },
  { kick: 'Grand Débat Tech', title: 'Faut-il craindre l\'intelligence artificielle en milieu scolaire ?', meta: '1:16:07', id: 'nu59ufftqZ4' },
  { kick: 'Formation', title: 'Augmenter sa productivité avec l\'IA', meta: '1:08:22', id: 'i_7SlR1bUEk' },
  { kick: 'Grand Débat Tech', title: 'L\'IA va-t-elle détruire nos emplois ou créer de nouvelles opportunités ?', meta: '35:00', id: 'hbLpDjowqDo' },
  { kick: 'Analyse IA', title: 'Présidentielle 2025 : ce que pensent vraiment les Camerounais (Analyse IA exclusive)', meta: '8:47', id: 'wLXOB2W-s6Y' },
  { kick: 'Formation', title: 'Apprendre à coder avec l\'IA ? Voici la formation Vibe Coding', meta: '1:34', id: 'hVGZZT45Qxs' },
];
---
<section class="section" id="emissions">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">02 — Nos émissions</span>
      <h2 class="sec-title">La marque, en action.</h2>
      <p class="lead">Débats et formations, déjà en ligne sur notre chaîne. L'IA à l'école, le vibe coding, la productivité, la place de l'Afrique dans la tech.</p>
    </div>

    <div class="em-grid reveal">
      {videos.map((v) => (
        <a class="em card-hover" href={`https://www.youtube.com/watch?v=${v.id}`} target="_blank" rel="noopener noreferrer">
          <div class="em__thumb">
            <img class="em__img" src={`https://img.youtube.com/vi/${v.id}/hqdefault.jpg`} alt={v.title} loading="lazy" width="480" height="360" />
            <div class="em__play" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M8 5v14l11-7z"/></svg>
            </div>
            <span class="em__dur">{v.meta}</span>
          </div>
          <div class="em__body">
            <span class="em__kick">{v.kick}</span>
            <h3 class="em__title">{v.title}</h3>
          </div>
        </a>
      ))}
    </div>

    <div class="em-cta reveal">
      <a href={CHANNEL} target="_blank" rel="noopener noreferrer" class="btn btn--indigo">
        <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.3 3.6-6.3 3.6Z"/></svg>
        Voir la chaîne · {videos.length} vidéos
      </a>
    </div>
  </div>
</section>

<style>
  .em-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-sm); }
  .em {
    border-radius: var(--r-md);
    overflow: hidden;
    border: 1px solid var(--sable-d);
    background: #fff;
    display: block;
  }
  .em__thumb {
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
    background: var(--indigo);
  }
  .em__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .em__play {
    position: absolute; z-index: 2; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--ocre); color: var(--encre);
    display: flex; align-items: center; justify-content: center;
    transition: transform .22s;
  }
  .em:hover .em__play { transform: translate(-50%, -50%) scale(1.06); }
  .em__dur {
    position: absolute; z-index: 2; bottom: 6px; right: 6px;
    font-family: var(--mono); font-size: .64rem;
    background: rgba(0,0,0,.7); color: #fff;
    padding: 2px 6px; border-radius: 4px;
  }
  .em__body { padding: 10px 12px 14px; }
  .em__kick { font-family: var(--mono); font-size: .6rem; letter-spacing: .12em; text-transform: uppercase; color: var(--charbon); }
  .em__title { font-family: var(--display); font-weight: 700; font-size: .84rem; margin-top: 5px; line-height: 1.2; letter-spacing: -.01em; color: var(--encre); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .em-cta { margin-top: var(--sp-lg); }

  @media (max-width: 1000px) { .em-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .em-grid { grid-template-columns: 1fr; } }
</style>
