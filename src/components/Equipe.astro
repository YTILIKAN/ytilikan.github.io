---
const membres = [
  {
    name: 'Hammel Brayan TAGAKOU',
    role: 'Chef des opérations · Responsable éditorial',
    body: "Anime les émissions en tant que modérateur, supervise les orientations éditoriales et coordonne les équipes.",
    linkedin: '#',
  },
  {
    name: 'Michel NIPBIEBA',
    role: 'Responsable technique',
    body: "Supervise la partie technique des tournages, image, son, lumière. Intervenant permanent, expertise terrain.",
    linkedin: '#',
  },
  {
    name: 'Christian Parfait NEBOT',
    role: 'Responsable pédagogique',
    body: "Garant de la validité scientifique et technique des contenus, élabore la ligne de formation tech.",
    linkedin: '#',
  },
  {
    name: 'Stelle',
    role: 'Communication & journaliste tech',
    body: "Prépare et présente la revue de presse, assure la veille tech et gère les réseaux sociaux.",
    linkedin: '#',
  },
  {
    name: 'Honorine',
    role: 'Relations extérieures',
    body: "Coordonne les intervenants, gère les relations partenaires et la communication externe.",
    linkedin: '#',
  },
];
---
<section class="section" id="equipe">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">05 — Notre équipe</span>
      <h2 class="sec-title">Une équipe, une mission.</h2>
      <p class="lead">Chacun intervient à différentes étapes du projet, avec des responsabilités bien définies. Une structure agile au service de la vulgarisation tech en Afrique.</p>
    </div>

    <div class="team-photos reveal">
      <img src="/team-group.png" alt="L'équipe Y'TILIKAN en session de travail" class="team-photo team-photo--main" loading="lazy" />
      <img src="/team-podcast.png" alt="Enregistrement d'une émission Y'TILIKAN" class="team-photo team-photo--side" loading="lazy" />
    </div>

    <div class="tm-grid reveal">
      {membres.map((m) => (
        <article class="tm card-hover">
          <div class="tm__photo" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <div class="tm__info">
            <h3 class="tm__name">{m.name}</h3>
            <p class="tm__role">{m.role}</p>
            <p class="tm__body">{m.body}</p>
            {m.linkedin !== '#' && (
              <a href={m.linkedin} class="tm__linkedin" target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team-photos { display: grid; grid-template-columns: 2fr 1fr; gap: var(--sp-sm); margin-bottom: var(--sp-lg); }
  .team-photo { width: 100%; border-radius: var(--r-md); object-fit: cover; display: block; }
  .team-photo--main { aspect-ratio: 16/9; }
  .team-photo--side { aspect-ratio: 3/2; }

  .tm-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-sm); }
  .tm {
    background: #fff;
    border: 1px solid var(--sable-d);
    border-radius: var(--r-md);
    padding: var(--sp-md);
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .tm__photo {
    width: 56px; height: 56px; flex-shrink: 0;
    border-radius: 50%;
    background: var(--sable);
    display: flex; align-items: center; justify-content: center;
    color: var(--sable-d);
  }
  .tm__info { min-width: 0; }
  .tm__name { font-family: var(--display); font-weight: 700; font-size: 1.04rem; letter-spacing: -.01em; margin-bottom: 2px; }
  .tm__role { font-family: var(--mono); font-size: .64rem; letter-spacing: .04em; color: var(--indigo); margin-bottom: 8px; text-transform: uppercase; }
  .tm__body { color: #4a433b; font-size: .85rem; line-height: 1.5; margin-bottom: 10px; }
  .tm__linkedin {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--mono); font-size: .66rem; color: #0A66C2;
    transition: color .2s;
  }
  .tm__linkedin:hover { color: var(--indigo); }

  @media (max-width: 860px) {
    .team-photos { grid-template-columns: 1fr; }
    .tm-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 500px) { .tm-grid { grid-template-columns: 1fr; } }
</style>
