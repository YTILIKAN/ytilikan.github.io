---
const membres = [
  {
    name: 'Hammel Brayan TAGAKOU',
    role: 'Chef des opérations · Responsable éditorial',
    body: "Anime les émissions en tant que modérateur, supervise les orientations éditoriales et coordonne les équipes pour la cohérence globale du projet.",
    initials: 'HT',
  },
  {
    name: 'Michel NIPBIEBA',
    role: 'Responsable technique',
    body: "Supervise la partie technique des tournages, image, son, lumière, et assure la qualité du rendu. Intervenant permanent, expertise terrain.",
    initials: 'MN',
  },
  {
    name: 'Christian Parfait NEBOT',
    role: 'Responsable pédagogique',
    body: "Garant de la validité scientifique et technique des contenus, élabore la ligne de formation tech et veille sur la qualité de l'ensemble.",
    initials: 'CN',
  },
  {
    name: 'Stelle',
    role: 'Communication & journaliste tech',
    body: "Prépare et présente la revue de presse, assure la veille tech et gère les réseaux sociaux (LinkedIn, Instagram, YouTube).",
    initials: 'S',
  },
  {
    name: 'Honorine',
    role: 'Relations extérieures',
    body: "Coordonne les intervenants, gère les relations partenaires et garantit la fluidité de communication entre l'équipe et les personnes externes.",
    initials: 'H',
  },
];
---
<section class="section" id="equipe">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">05 — Notre équipe</span>
      <h2 class="sec-title">Une équipe, une mission.</h2>
      <p class="lead">Chacun intervient à différentes étapes du projet, avec des responsabilités bien définies. Une structure agile au service de la vulgarisation tech en Afrique.</p>
    </div>

    <div class="team-photos reveal">
      <img src="/team-group.png" alt="L'équipe Y'TILIKAN en session de travail" class="team-photo team-photo--main" loading="lazy" />
      <img src="/team-podcast.png" alt="Enregistrement d'une émission Y'TILIKAN" class="team-photo team-photo--side" loading="lazy" />
    </div>

    <div class="tm-grid reveal">
      {membres.map((m) => (
        <article class="tm">
          <div class="tm__avatar">{m.initials}</div>
          <h3 class="tm__name">{m.name}</h3>
          <p class="tm__role">{m.role}</p>
          <p class="tm__body">{m.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team-photos { display: grid; grid-template-columns: 2fr 1fr; gap: var(--sp-sm); margin-bottom: var(--sp-lg); }
  .team-photo { width: 100%; border-radius: var(--r-md); object-fit: cover; display: block; }
  .team-photo--main { aspect-ratio: 16/9; }
  .team-photo--side { aspect-ratio: 3/2; }

  .tm-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-sm); }
  .tm {
    background: var(--ivoire);
    border: 1px solid var(--sable-d);
    border-radius: var(--r-md);
    padding: var(--sp-md);
    transition: transform .22s, box-shadow .22s;
  }
  .tm:hover { transform: translateY(-4px); box-shadow: 0 14px 30px rgba(22,19,17,.08); }
  .tm__avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    display: grid; place-items: center;
    font-family: var(--display); font-weight: 800; font-size: 1.05rem;
    background: var(--indigo); color: var(--ivoire);
    margin-bottom: 14px;
  }
  .tm__name { font-family: var(--display); font-weight: 700; font-size: 1.08rem; letter-spacing: -.01em; margin-bottom: 4px; }
  .tm__role { font-family: var(--mono); font-size: .66rem; letter-spacing: .04em; color: var(--indigo); margin-bottom: 12px; text-transform: uppercase; }
  .tm__body { color: #4a433b; font-size: .88rem; line-height: 1.5; }

  @media (max-width: 860px) {
    .team-photos { grid-template-columns: 1fr; }
    .tm-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 500px) { .tm-grid { grid-template-columns: 1fr; } }
</style>
