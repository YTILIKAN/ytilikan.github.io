---
const links = [
  { href: '#mission', label: 'Mission' },
  { href: '#programmes', label: 'Programmes' },
  { href: '#equipe', label: 'Équipe' },
  { href: '#projets', label: 'Projets' },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a href="#top" class="nav__brand" aria-label="Y'TILIKAN — accueil">
      <img src="/mark.svg" alt="" width="34" height="34" />
      <span class="nav__word">Y'TILIKAN</span>
    </a>

    <nav class="nav__links" aria-label="Navigation principale">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <a href="#contact" class="nav__cta">Rejoindre</a>

    <button class="nav__burger" aria-label="Menu" id="burger">
      <span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="mobile-menu">
    {links.map((l) => <a href={l.href} class="nav__mobile-link">{l.label}</a>)}
    <a href="#contact" class="nav__mobile-link nav__mobile-cta">Rejoindre</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    background: color-mix(in srgb, var(--yt-ink-950) 72%, transparent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }
  .nav.scrolled {
    border-bottom-color: var(--yt-border);
    background: color-mix(in srgb, var(--yt-ink-950) 88%, transparent);
  }
  .nav__inner {
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav__brand {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .nav__brand img { border-radius: 8px; display: block; }
  .nav__word {
    font-family: var(--yt-font-display);
    font-weight: 700;
    letter-spacing: 0.18em;
    font-size: 0.95rem;
  }
  .nav__links {
    display: flex;
    gap: 34px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .nav__links a {
    font-size: 0.86rem;
    color: var(--yt-text-dim);
    letter-spacing: 0.02em;
    transition: color 0.2s;
    position: relative;
  }
  .nav__links a:hover { color: var(--yt-text); }
  .nav__links a::after {
    content: "";
    position: absolute;
    left: 0; bottom: -6px;
    width: 0; height: 1px;
    background: var(--yt-accent);
    transition: width 0.25s;
  }
  .nav__links a:hover::after { width: 100%; }

  .nav__cta {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 9px 20px;
    border: 1px solid var(--yt-accent-deep);
    border-radius: 999px;
    color: var(--yt-accent);
    transition: all 0.22s;
  }
  .nav__cta:hover {
    background: var(--yt-accent);
    color: var(--yt-ink-950);
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .nav__burger span {
    width: 22px; height: 2px;
    background: var(--yt-text);
    transition: transform 0.25s, opacity 0.25s;
  }
  .nav__mobile {
    display: none;
    flex-direction: column;
    padding: 12px 24px 22px;
    border-top: 1px solid var(--yt-border);
    background: var(--yt-ink-950);
  }
  .nav__mobile.open { display: flex; }
  .nav__mobile-link {
    padding: 13px 0;
    color: var(--yt-text-dim);
    border-bottom: 1px solid color-mix(in srgb, var(--yt-border) 50%, transparent);
    font-size: 0.95rem;
  }
  .nav__mobile-cta {
    color: var(--yt-accent);
    font-weight: 600;
    border-bottom: none;
  }

  @media (max-width: 820px) {
    .nav__links, .nav__cta { display: none; }
    .nav__burger { display: flex; }
  }
</style>

<script>
  const nav = document.querySelector('.nav');
  const onScroll = () => {
    if (window.scrollY > 12) nav?.classList.add('scrolled');
    else nav?.classList.remove('scrolled');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => menu.classList.remove('open'))
  );
</script>
