---
import { SITE, formatCount } from '../data/site';

const stats = [
  { n: SITE.youtube.views, label: 'Vues YouTube', sub: 'Formations et débats en ligne', display: formatCount(SITE.youtube.views) },
  { n: SITE.emissionsCount, label: 'Émissions', sub: 'Débats et formations' },
  { n: 4, label: 'Projets open-source', sub: 'AfriBench, AfroLang, AfroTech-Pulse, Dira' },
];
---
<section class="section stats-band">
  <div class="wrap">
    <div class="stats-grid reveal">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat__n" data-target={s.n} data-display={s.display}>{s.display ?? '0'}</span>
          <span class="stat__label">{s.label}</span>
          <span class="stat__sub">{s.sub}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-band { padding: 48px 0; background: #fff; border-top: 1px solid var(--sable-d); border-bottom: 1px solid var(--sable-d); }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: center; }
  .stat { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .stat__n { font-family: var(--display); font-weight: 800; font-size: 2.6rem; color: var(--indigo); line-height: 1; transition: color .3s; }
  .stat:hover .stat__n { color: var(--ocre); }
  .stat__label { font-family: var(--display); font-weight: 700; font-size: .95rem; color: var(--encre); }
  .stat__sub { font-size: .78rem; color: var(--muted); }

  @media (max-width: 860px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  }
  @media (max-width: 500px) { .stats-grid { grid-template-columns: 1fr; } }
</style>

<script>
  function formatStatValue(n: number, display?: string) {
    return display ?? String(n);
  }

  function animateCounters() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.stat__n[data-target]').forEach((el) => {
        const htmlEl = el as HTMLElement;
        const target = parseInt(htmlEl.dataset.target ?? '0', 10);
        const display = htmlEl.dataset.display;
        const isPct = htmlEl.closest('.stat')?.querySelector('.stat__label')?.textContent?.includes('%');
        htmlEl.textContent = isPct ? target + '%' : formatStatValue(target, display);
      });
      return;
    }
    const counters = document.querySelectorAll('.stat__n[data-target]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target ?? '0', 10);
        const display = el.dataset.display;
        const isPct = el.textContent?.includes('%') ?? false;
        const duration = 1400;
        const start = performance.now();
        function tick(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(target * eased);
          el.textContent = isPct
            ? current + '%'
            : progress >= 1 && display
              ? display
              : String(current);
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.4 });
    counters.forEach(c => observer.observe(c));
  }
  animateCounters();
</script>
