---
const projetlist = [
  {
    name: 'AfriBench',
    tag: 'ML · Benchmark',
    desc: "Le premier benchmark d'évaluation des grands modèles de langage sur des connaissances africaines francophones. QCM multi-catégories, reproductible, ouvert aux contributions.",
    link: 'https://github.com/YTILIKAN/AfriBench',
    linkLabel: 'github.com/YTILIKAN/AfriBench',
    status: '★1 · Public',
  },
  {
    name: 'AfroLang-Library',
    tag: 'Data · NLP',
    desc: "La plus grande bibliothèque organisée de datasets de langues africaines — navigable, filtrable, ouverte aux contributions. Infrastructure essentielle pour l'IA en langues africaines.",
    link: 'https://github.com/YTILIKAN/AfroLang-Library',
    linkLabel: 'github.com/YTILIKAN/AfroLang-Library',
    status: 'Public',
  },
  {
    name: 'AfroTech-Pulse',
    tag: 'Veille · Newsletter',
    desc: "Dashboard de veille IA pour le continent africain + pipeline newsletter automatisée publiée chaque lundi. Python, scraping, curation.",
    link: 'https://github.com/YTILIKAN/AfroTech-Pulse',
    linkLabel: 'github.com/YTILIKAN/AfroTech-Pulse',
    status: 'Public',
  },
  {
    name: 'Dira Browser',
    tag: 'Navigateur · C++',
    desc: "Un navigateur web axé sur la souveraineté et le respect de la vie privée, basé sur Chromium. « Dira » — la boussole, en swahili. Fork de Brave, en rebranding actif.",
    link: 'https://github.com/YTILIKAN/brave-core',
    linkLabel: 'github.com/YTILIKAN/brave-core',
    status: 'Fork · En développement',
  },
];
---
<section class="section" id="projets">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">01 — Initiatives &amp; projets open-source</span>
      <h2 class="sec-title">L'écosystème Y'TILIKAN.</h2>
      <p class="lead">Tous nos projets sont ouverts, documentés et prêts aux contributions. De l'évaluation des LLMs aux datasets de langues africaines en passant par un navigateur souverain — l'infrastructure d'une IA africaine se construit ici.</p>
    </div>

    <div class="pj-grid reveal">
      {projetlist.map((p) => (
        <article class="pj">
          <div class="pj__top">
            <span class="pj__tag mono">{p.tag}</span>
            <span class="pj__status">{p.status}</span>
          </div>
          <h3 class="pj__name">{p.name}</h3>
          <p class="pj__body">{p.desc}</p>
          <a class="pj__link" href={p.link} target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="flex:none"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.604-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
            {p.linkLabel}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pj-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .pj {
    background: var(--ivoire);
    border: 1px solid var(--sable-d);
    border-radius: 14px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: transform .22s, box-shadow .22s;
  }
  .pj:hover { transform: translateY(-4px); box-shadow: 0 14px 30px rgba(22,19,17,.08); }
  .pj__top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .pj__tag {
    font-family: var(--mono); font-size: .62rem; letter-spacing: .12em; text-transform: uppercase; color: var(--kola);
    background: color-mix(in srgb, var(--kola) 10%, transparent);
    padding: 3px 8px; border-radius: 4px;
  }
  .pj__status { font-family: var(--mono); font-size: .62rem; letter-spacing: .04em; color: #6a6156; }
  .pj__name { font-family: var(--display); font-weight: 800; font-size: 1.35rem; margin-bottom: 10px; letter-spacing: -.01em; }
  .pj__body { color: #4a433b; font-size: .9rem; line-height: 1.55; flex: 1; margin-bottom: 16px; }
  .pj__link {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: .72rem; color: var(--indigo);
    transition: color .2s;
  }
  .pj__link:hover { color: var(--ocre); }

  @media (max-width: 860px) { .pj-grid { grid-template-columns: 1fr; } }
</style>
