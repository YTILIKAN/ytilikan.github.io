---
const projets = [
  {
    name: 'AfriBench',
    tag: 'Benchmark IA',
    body: "Le premier benchmark d'évaluation des modèles de langage sur des connaissances africaines francophones. QCM multi-catégories, ouvert et reproductible.",
    link: 'https://ytilikan.github.io/AfriBench',
    linkLabel: 'ytilikan.github.io/AfriBench',
    status: 'Prototype v0.1',
  },
  {
    name: 'Dira',
    tag: 'Navigateur',
    body: "Un navigateur web axé souveraineté et respect de la vie privée. « Dira » — la boussole, en swahili. Une brique de notre écosystème numérique africain.",
    link: '',
    linkLabel: 'Bientôt',
    status: 'En développement',
  },
  {
    name: 'Formation Tech',
    tag: 'Éducation',
    body: "Notre programme pédagogique : IA, programmation, cybersécurité et cloud. Des vidéos courtes, gratuites, sans jargon, pour apprendre à son rythme.",
    link: '#programmes',
    linkLabel: 'Voir les programmes',
    status: 'En ligne',
  },
];
---
<section class="section" id="projets">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">05 — Initiatives &amp; projets</span>
      <h2 class="sec-title">Au-delà des émissions.</h2>
      <p class="lead">Y'TILIKAN construit un écosystème : outils ouverts, recherche et formation pour une Afrique qui participe pleinement au numérique.</p>
    </div>

    <div class="pj-grid reveal">
      {projets.map((p) => (
        <article class="pj">
          <div class="pj__top">
            <span class="pj__tag">{p.tag}</span>
            <span class="pj__status">{p.status}</span>
          </div>
          <h3 class="pj__name">{p.name}</h3>
          <p class="pj__body">{p.body}</p>
          {p.link ? (
            <a class="pj__link" href={p.link} target={p.link.startsWith('http') ? '_blank' : null} rel={p.link.startsWith('http') ? 'noopener' : null}>
              {p.linkLabel}<span class="pj__arrow" aria-hidden="true">→</span>
            </a>
          ) : (
            <span class="pj__link pj__link--soon">{p.linkLabel}</span>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pj-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .pj {
    background: var(--sable);
    border: 1px solid var(--sable-d);
    border-radius: 18px;
    padding: 28px 26px 26px;
    display: flex;
    flex-direction: column;
    border-bottom: 3px solid var(--ocre);
    transition: transform .24s, box-shadow .24s;
  }
  .pj:hover { transform: translateY(-5px); box-shadow: 0 18px 40px rgba(22,19,17,.10); }
  .pj__top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
  .pj__tag { font-family: var(--mono); font-size: .66rem; letter-spacing: .14em; text-transform: uppercase; color: var(--kola); }
  .pj__status {
    font-family: var(--mono); font-size: .64rem; letter-spacing: .06em; color: #6a6156;
    border: 1px solid var(--sable-d); background: #fff; padding: 3px 9px; border-radius: 40px;
  }
  .pj__name { font-family: var(--display); font-weight: 800; font-size: 1.5rem; margin-bottom: 12px; letter-spacing: -.01em; }
  .pj__body { color: #4a433b; font-size: .92rem; line-height: 1.55; flex: 1; margin-bottom: 20px; }
  .pj__link { display: inline-flex; align-items: center; gap: 8px; font-family: var(--display); font-weight: 700; font-size: .88rem; color: var(--indigo); }
  .pj__arrow { transition: transform .2s; }
  .pj__link:hover .pj__arrow { transform: translateX(4px); }
  .pj__link--soon { color: #8a8175; }

  @media (max-width: 860px) { .pj-grid { grid-template-columns: 1fr; } }
</style>
