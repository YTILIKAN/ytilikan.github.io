---
const CHANNEL = 'https://www.youtube.com/@YTILIKAN';
---
<header class="cover" id="top">
  <div class="cover__overlay" aria-hidden="true"></div>
  <svg class="cover__pattern" aria-hidden="true"><rect width="100%" height="100%" fill="url(#maskpat)" opacity="0.10"/></svg>
  <div class="wrap cover__inner">
    <span class="eyebrow cover__tag">Communauté · IA · Afrique francophone</span>

    <div class="cover__lockup reveal">
      <img src="/logo-white.jpg" alt="" class="cover__logo" width="108" height="108" fetchpriority="high" decoding="async" />
      <h1 class="cover__word">Y<span class="apos">'</span>TILIKAN</h1>
    </div>

    <p class="cover__tagline reveal" data-delay="80"><em>« Ce n'est pas sorcier. »</em></p>

    <p class="cover__sub reveal" data-delay="160">
      Formations gratuites, émissions en français et outils open-source pour
      rendre l'intelligence artificielle accessible à l'Afrique francophone et sa diaspora.
    </p>

    <div class="cover__cta reveal" data-delay="240">
      <a href="#emissions" class="btn btn--gold">Voir les émissions</a>
      <a href={CHANNEL} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">Chaîne YouTube</a>
    </div>

    <p class="cover__translate reveal" data-delay="320">Du mooré (Burkina Faso) · vulgarisation tech sans jargon</p>
  </div>
</header>

<style>
  .cover {
    background: var(--indigo) url('/hero-bg.jpg') center / cover no-repeat;
    background-blend-mode: overlay;
    color: var(--ivoire);
    position: relative;
    overflow: hidden;
    min-height: 92vh;
    display: flex;
    align-items: center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cover { animation: hero-drift 14s ease-in-out infinite alternate; }
    @keyframes hero-drift { 0% { background-position: center top; } 100% { background-position: center bottom; } }
  }
  .cover__overlay { position: absolute; inset: 0; background: linear-gradient(135deg, var(--indigo-d) 0%, transparent 55%, var(--indigo) 100%); z-index: 1; }
  .cover__pattern { position: absolute; inset: 0; z-index: 2; pointer-events: none; }
  .cover__inner { position: relative; z-index: 3; padding: calc(68px + 48px) 0 80px; width: 100%; }
  .cover__tag { color: var(--ocre); }

  .cover__lockup {
    display: flex;
    align-items: center;
    gap: 26px;
    margin: 26px 0 30px;
    flex-wrap: wrap;
  }
  .cover__logo { width: 108px; height: 108px; border-radius: 12px; object-fit: contain; flex: none; }
  .cover__word {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(3rem, 10vw, 6rem);
    letter-spacing: -.01em;
    line-height: .9;
  }
  .cover .apos { color: var(--ocre); }

  .cover__tagline {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(1.6rem, 4.5vw, 2.8rem);
    letter-spacing: -.01em;
    margin-bottom: 18px;
  }
  .cover__tagline em { font-style: normal; color: var(--ocre); }

  .cover__sub {
    max-width: 52ch;
    font-size: 1.14rem;
    color: #d9d2c4;
  }

  .cover__cta {
    display: flex;
    gap: 14px;
    margin: 38px 0 34px;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--mono);
    font-weight: 700;
    font-size: .72rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 13px 26px;
    border-radius: var(--r-full);
    transition: transform .2s, background .2s, border-color .2s, color .2s;
  }
  .btn--gold { background: var(--ocre); color: var(--encre); }
  .btn--gold:hover { background: var(--ocre-d); transform: translateY(-2px); }
  .btn--ghost { border: 1.5px solid #ffffff33; color: var(--ivoire); }
  .btn--ghost:hover { border-color: var(--ocre); color: var(--ocre); }

  .cover__translate {
    font-family: var(--mono);
    font-size: .72rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #b9c0d6;
    border-left: 2px solid var(--ocre);
    padding-left: 14px;
  }

  @media (max-width: 860px) {
    .cover__logo { width: 76px; height: 76px; }
    .cover__inner { padding-top: calc(68px + 32px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn--gold:hover, .btn--ghost:hover { transform: none; }
  }
</style>
