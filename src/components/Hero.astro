---
import { SITE, formatCount } from '../data/site';
---
<header class="cover" id="top">
  <div class="cover__overlay" aria-hidden="true"></div>
  <svg class="cover__pattern" aria-hidden="true"><rect width="100%" height="100%" fill="url(#maskpat)" opacity="0.08"/></svg>

  <div class="wrap cover__inner">
    <div class="cover__content">
      <h1 class="cover__headline reveal" data-delay="80">
        La tech et l'IA, à la portée de l'Afrique francophone
      </h1>

      <p class="cover__hook reveal" data-delay="160">
        <em>«&nbsp;Ce n'est pas sorcier.&nbsp;»</em>
      </p>

      <p class="cover__sub reveal" data-delay="240">
        Des émissions en français et des formations concrètes pour comprendre,
        maîtriser et créer la technologie.
      </p>

      <p class="cover__proof reveal" data-delay="320">
        <a href={SITE.youtube.url} target="_blank" rel="noopener noreferrer" class="cover__proof-link">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.3 3.6-6.3 3.6Z"/></svg>
          {formatCount(SITE.youtube.subscribers)} abonnés · {formatCount(SITE.youtube.views)} vues · {SITE.emissionsCount} émissions
        </a>
      </p>

      <div class="cover__cta reveal" data-delay="400">
        <a href="#emissions" class="btn btn--gold">Voir les émissions</a>
        <a href="#participer" class="cover__cta-secondary">Comment participer</a>
      </div>
    </div>
  </div>

  <a href="#essence" class="cover__scroll" aria-label="Défiler vers le contenu">
    <span>Découvrir</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </a>
</header>

<style>
  .cover {
    background: var(--indigo) url('/hero-bg.jpg') center / cover no-repeat;
    color: var(--ivoire);
    position: relative;
    overflow: hidden;
    min-height: 100svh;
    display: flex;
    align-items: center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cover { animation: hero-drift 18s ease-in-out infinite alternate; }
    @keyframes hero-drift { 0% { background-position: center 20%; } 100% { background-position: center 80%; } }
  }

  .cover__overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      102deg,
      rgba(10, 8, 6, 0.94) 0%,
      rgba(10, 8, 6, 0.82) 38%,
      rgba(10, 8, 6, 0.55) 58%,
      rgba(10, 8, 6, 0.2) 100%
    );
  }
  .cover__pattern { position: absolute; inset: 0; z-index: 2; pointer-events: none; }
  .cover__inner {
    position: relative; z-index: 3;
    padding: calc(var(--nav-h) + 56px) 0 96px;
    width: 100%;
  }
  .cover__content { max-width: 660px; }

  .cover__headline {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    letter-spacing: -.025em;
    line-height: 1.05;
    text-shadow: 0 2px 24px rgba(0,0,0,.35);
    margin-bottom: 14px;
  }

  .cover__hook {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(1.2rem, 2.8vw, 1.55rem);
    letter-spacing: -.01em;
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .cover__hook em { font-style: normal; color: var(--ocre); }

  .cover__sub {
    max-width: 52ch;
    font-size: 1.08rem;
    color: rgba(250,249,246,.78);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .cover__proof { margin-bottom: 4px; }

  .cover__proof-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: .68rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(250,249,246,.72);
    transition: color .2s;
  }
  .cover__proof-link svg { color: var(--ocre); flex: none; }
  .cover__proof-link:hover { color: var(--ivoire); }

  .cover__cta {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 28px 0 28px;
    flex-wrap: wrap;
  }

  .cover__cta-secondary {
    font-family: var(--mono);
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(250,249,246,.65);
    border-bottom: 1px solid rgba(250,249,246,.25);
    padding-bottom: 2px;
    transition: color .2s, border-color .2s;
  }
  .cover__cta-secondary:hover {
    color: var(--ocre);
    border-bottom-color: var(--ocre);
  }

  .cover__scroll {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: rgba(250,249,246,.55);
    font-family: var(--mono);
    font-size: .62rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    transition: color .2s;
  }
  .cover__scroll:hover { color: var(--ocre); }
  @media (prefers-reduced-motion: no-preference) {
    .cover__scroll svg { animation: scroll-bob 2s ease-in-out infinite; }
    @keyframes scroll-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(4px); } }
  }

  @media (max-width: 860px) {
    .cover__inner { padding-top: calc(var(--nav-h) + 36px); padding-bottom: 80px; }
    .cover__scroll { display: none; }
  }

  @media (min-width: 900px) {
    .cover__inner { padding-bottom: 110px; }
  }
</style>
