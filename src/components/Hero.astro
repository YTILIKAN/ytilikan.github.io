---
const CHANNEL = 'https://www.youtube.com/@YTILIKAN';
---
<header class="cover" id="top">
  <div class="cover__overlay" aria-hidden="true"></div>
  <svg class="cover__pattern" aria-hidden="true"><rect width="100%" height="100%" fill="url(#maskpat)" opacity="0.08"/></svg>

  <div class="wrap cover__inner">
    <div class="cover__content">
      <span class="eyebrow cover__tag">Communauté · IA · Afrique francophone</span>

      <div class="cover__lockup reveal">
        <img src="/logo-white.jpg" alt="" class="cover__logo" width="88" height="88" fetchpriority="high" decoding="async" />
        <h1 class="cover__word">Y<span class="apos">'</span>TILIKAN</h1>
      </div>

      <p class="cover__tagline reveal" data-delay="80">
        <em>« Ce n'est pas sorcier. »</em>
        <span class="cover__tagline-sub">Vulgariser la tech et l'IA pour l'Afrique francophone.</span>
      </p>

      <p class="cover__sub reveal" data-delay="160">
        Formations gratuites, émissions en français et outils open-source —
        pour que chacun comprenne et participe à la révolution numérique.
      </p>

      <div class="cover__cta reveal" data-delay="240">
        <a href="#emissions" class="btn btn--gold">Voir les émissions</a>
        <a href="#contact" class="btn btn--ghost">Rejoindre la communauté</a>
      </div>

      <p class="cover__translate reveal" data-delay="320">Du mooré (Burkina Faso) · « ce n'est pas sorcier »</p>
    </div>
  </div>

  <a href="#essence" class="cover__scroll" aria-label="Défiler vers le contenu">
    <span>Découvrir</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </a>
</header>

<style>
  .cover {
    background: var(--indigo) url('/hero-bg.jpg') center / cover no-repeat;
    color: var(--ivoire);
    position: relative;
    overflow: hidden;
    min-height: 100svh;
    display: flex;
    align-items: center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cover { animation: hero-drift 18s ease-in-out infinite alternate; }
    @keyframes hero-drift { 0% { background-position: center 20%; } 100% { background-position: center 80%; } }
  }

  .cover__overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      102deg,
      rgba(26, 33, 67, 0.94) 0%,
      rgba(26, 33, 67, 0.82) 38%,
      rgba(36, 46, 88, 0.55) 58%,
      rgba(36, 46, 88, 0.2) 100%
    );
  }
  .cover__pattern { position: absolute; inset: 0; z-index: 2; pointer-events: none; }
  .cover__inner {
    position: relative; z-index: 3;
    padding: calc(var(--nav-h) + 56px) 0 96px;
    width: 100%;
  }
  .cover__content { max-width: 620px; }

  .cover__tag { color: var(--ocre); margin-bottom: 4px; }

  .cover__lockup {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 20px 0 24px;
    flex-wrap: wrap;
  }
  .cover__logo {
    width: 88px; height: 88px;
    border-radius: 12px;
    object-fit: contain;
    flex: none;
    box-shadow: 0 8px 32px rgba(0,0,0,.25);
  }
  .cover__word {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(2.6rem, 8vw, 5.2rem);
    letter-spacing: -.02em;
    line-height: .92;
    text-shadow: 0 2px 24px rgba(0,0,0,.35);
  }
  .cover .apos { color: var(--ocre); }

  .cover__tagline {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(1.45rem, 3.8vw, 2.2rem);
    letter-spacing: -.01em;
    margin-bottom: 16px;
    line-height: 1.15;
  }
  .cover__tagline em { font-style: normal; color: var(--ocre); display: block; margin-bottom: 6px; }
  .cover__tagline-sub {
    display: block;
    font-family: var(--body);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(245,239,225,.88);
    letter-spacing: 0;
  }

  .cover__sub {
    max-width: 48ch;
    font-size: 1.08rem;
    color: rgba(245,239,225,.78);
    line-height: 1.65;
    margin-bottom: 4px;
  }

  .cover__cta {
    display: flex;
    gap: 12px;
    margin: 32px 0 28px;
    flex-wrap: wrap;
  }

  .cover__translate {
    font-family: var(--mono);
    font-size: .68rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(185,192,214,.9);
    border-left: 2px solid var(--ocre);
    padding-left: 14px;
  }

  .cover__scroll {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: rgba(245,239,225,.55);
    font-family: var(--mono);
    font-size: .62rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    transition: color .2s;
  }
  .cover__scroll:hover { color: var(--ocre); }
  @media (prefers-reduced-motion: no-preference) {
    .cover__scroll svg { animation: scroll-bob 2s ease-in-out infinite; }
    @keyframes scroll-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(4px); } }
  }

  @media (max-width: 860px) {
    .cover__logo { width: 64px; height: 64px; }
    .cover__inner { padding-top: calc(var(--nav-h) + 36px); padding-bottom: 80px; }
    .cover__scroll { display: none; }
  }

  @media (min-width: 900px) {
    .cover__inner { padding-bottom: 110px; }
  }
</style>
