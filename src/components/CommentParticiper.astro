---
import { SITE } from '../data/site';

const steps = [
  {
    n: '01',
    title: 'Regarder & apprendre',
    body: 'Émissions, débats et formations gratuites publiés sur notre chaîne YouTube, en français et sans prérequis.',
    cta: 'Voir la chaîne',
    href: SITE.youtube.url,
    external: true,
  },
  {
    n: '02',
    title: 'Contribuer au code',
    body: 'Benchmarks, datasets, outils de veille : nos projets sont ouverts. Issues, pull requests et données bienvenues.',
    cta: 'Ouvrir GitHub',
    href: SITE.github,
    external: true,
  },
  {
    n: '03',
    title: 'Collaborer',
    body: 'Intervenant, invité, partenaire ou école : écris-nous pour construire quelque chose ensemble.',
    cta: 'Nous écrire',
    href: SITE.email,
    external: false,
  },
];
---
<section class="section steps" id="participer" aria-labelledby="participer-title">
  <div class="wrap">
    <div class="section-head section-head--center reveal">
      <span class="eyebrow">Comment participer</span>
      <h2 class="sec-title" id="participer-title">Trois étapes, dès aujourd'hui.</h2>
      <p class="lead">Pas de formulaire d'inscription : regarde, contribue ou écris-nous. Chaque voie est concrète et gratuite.</p>
    </div>

    <ol class="steps-grid reveal">
      {steps.map((s) => (
        <li class="step card-hover">
          <span class="step__n" aria-hidden="true">{s.n}</span>
          <h3 class="step__title">{s.title}</h3>
          <p class="step__body">{s.body}</p>
          <a
            class="step__cta"
            href={s.href}
            target={s.external ? '_blank' : undefined}
            rel={s.external ? 'noopener noreferrer' : undefined}
          >
            {s.cta}
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .steps { background: var(--surface); }

  .steps-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-sm);
    counter-reset: none;
  }

  .step {
    display: flex;
    flex-direction: column;
    background: var(--ivoire);
    border: 1px solid var(--sable-d);
    border-radius: var(--r-md);
    padding: 28px 24px;
    position: relative;
    overflow: hidden;
  }

  .step__n {
    font-family: var(--display);
    font-weight: 800;
    font-size: 2.8rem;
    line-height: 1;
    color: color-mix(in srgb, var(--ocre) 22%, transparent);
    margin-bottom: 12px;
  }

  .step__title {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -.01em;
    margin-bottom: 10px;
  }

  .step__body {
    color: var(--muted);
    font-size: .9rem;
    line-height: 1.55;
    flex: 1;
    margin-bottom: 18px;
  }

  .step__cta {
    font-family: var(--mono);
    font-size: .68rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--encre);
    transition: color .2s;
  }

  .step__cta:hover { color: var(--ocre); }

  @media (max-width: 860px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
