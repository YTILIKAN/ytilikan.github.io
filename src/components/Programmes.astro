---
const programmes = [
  {
    tag: 'Émission principale',
    title: "Y'TILIKAN",
    duration: '≈ 1 heure',
    body: "L'émission phare. Format structuré : introduction du thème et des invités, astuce tech du jour, revue de l'actualité, Grand Débat Tech, et mot de la fin.",
    points: ['Astuce tech du jour', "Revue de l'actualité", 'Grand Débat Tech'],
  },
  {
    tag: 'Interview',
    title: 'Face à Michel',
    duration: 'One-on-one',
    body: "Une personnalité de la tech — entrepreneur, développeur, designer, chercheur — raconte son parcours, ses défis, ses projets et sa vision du numérique.",
    points: ['Parcours & défis', 'Talents africains', 'Vision du futur'],
  },
  {
    tag: 'Pédagogie',
    title: 'Formation Tech',
    duration: '5 – 15 min',
    body: "Courtes vidéos pour apprendre outils, concepts et pratiques : IA, programmation, cybersécurité, cloud, et outils collaboratifs.",
    points: ['IA & Python', 'Cybersécurité', 'Cloud & productivité'],
  },
];
---
<section class="prog section-pad" id="programmes">
  <div class="container">
    <div class="prog__head">
      <p class="eyebrow reveal">Nos programmes</p>
      <h2 class="prog__title reveal" data-delay="80">
        Informer, débattre, former, inspirer.
      </h2>
      <p class="prog__lead reveal" data-delay="160">
        Des formats complémentaires pour toucher tous les publics — du simple
        curieux au professionnel du numérique.
      </p>
    </div>

    <div class="prog__grid">
      {programmes.map((p, i) => (
        <article class="pcard reveal" data-delay={String(i * 100)}>
          <div class="pcard__top">
            <span class="pcard__tag mono">{p.tag}</span>
            <span class="pcard__dur mono">{p.duration}</span>
          </div>
          <h3 class="pcard__title">{p.title}</h3>
          <p class="pcard__body">{p.body}</p>
          <ul class="pcard__points">
            {p.points.map((pt) => (
              <li><span class="tick" aria-hidden="true"></span>{pt}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .prog { background: var(--yt-ink-900); }
  .prog__head { max-width: 660px; margin-bottom: 58px; }
  .prog__title { font-size: clamp(1.7rem, 3.4vw, 2.6rem); margin: 20px 0 18px; }
  .prog__lead { color: var(--yt-text-dim); font-size: 1.06rem; }

  .prog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  .pcard {
    background: var(--yt-ink-950);
    border: 1px solid var(--yt-border);
    border-radius: var(--yt-radius-lg);
    padding: 30px 28px 32px;
    display: flex;
    flex-direction: column;
    transition: transform 0.28s, border-color 0.28s;
    position: relative;
    overflow: hidden;
  }
  .pcard::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--yt-accent), transparent);
    opacity: 0;
    transition: opacity 0.28s;
  }
  .pcard:hover { transform: translateY(-6px); border-color: var(--yt-accent-deep); }
  .pcard:hover::before { opacity: 1; }

  .pcard__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 22px;
  }
  .pcard__tag { color: var(--yt-accent); }
  .pcard__dur { color: var(--yt-text-faint); }

  .pcard__title { font-size: 1.5rem; font-weight: 800; margin-bottom: 14px; }
  .pcard__body { color: var(--yt-text-dim); font-size: 0.94rem; line-height: 1.65; flex: 1; }

  .pcard__points {
    list-style: none;
    padding: 0;
    margin: 22px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pcard__points li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.86rem;
    color: var(--yt-text);
  }
  .tick {
    width: 15px; height: 15px;
    flex-shrink: 0;
    border-radius: 4px;
    background: color-mix(in srgb, var(--yt-amber-600) 18%, transparent);
    position: relative;
  }
  .tick::after {
    content: "";
    position: absolute;
    left: 4.5px; top: 2px;
    width: 4px; height: 8px;
    border: solid var(--yt-accent);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
</style>
