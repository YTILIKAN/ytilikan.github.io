---
const programmes = [
  {
    kick: 'Émission principale',
    title: "Y'TILIKAN",
    duration: '≈ 1 heure',
    body: "L'émission phare. Format structuré : introduction du thème et des invités, astuce tech du jour, revue de l'actualité, Grand Débat Tech, et mot de la fin.",
    points: ['Astuce tech du jour', "Revue de l'actualité", 'Grand Débat Tech'],
  },
  {
    kick: 'Interview',
    title: 'Face à Michel',
    duration: 'One-on-one',
    body: "Une personnalité de la tech, entrepreneur, développeur, designer ou chercheur, raconte son parcours, ses défis, ses projets et sa vision du numérique.",
    points: ['Parcours & défis', 'Talents africains', 'Vision du futur'],
  },
  {
    kick: 'Pédagogie',
    title: 'Formation Tech',
    duration: '5 – 15 min',
    body: "Courtes vidéos pour apprendre outils, concepts et pratiques : IA, programmation, cybersécurité, cloud, et outils collaboratifs.",
    points: ['IA & Python', 'Cybersécurité', 'Cloud & productivité'],
  },
];
---
<section class="section" id="programmes">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">04 — Nos programmes</span>
      <h2 class="sec-title">Informer, débattre, former, inspirer.</h2>
      <p class="lead">Des formats complémentaires pour toucher tous les publics, du simple curieux au professionnel du numérique.</p>
    </div>

    <div class="prog-grid reveal">
      {programmes.map((p) => (
        <article class="pcard">
          <div class="pcard__top">
            <span class="pcard__kick">{p.kick}</span>
            <span class="pcard__dur">{p.duration}</span>
          </div>
          <h3 class="pcard__title">{p.title}</h3>
          <p class="pcard__body">{p.body}</p>
          <ul class="pcard__points">
            {p.points.map((pt) => (
              <li><svg class="pcard__eye" viewBox="0 0 100 60"><use href="#eye"/></svg>{pt}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .prog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .pcard {
    background: #fff;
    border: 1px solid var(--sable-d);
    border-radius: 18px;
    padding: 30px 28px 32px;
    display: flex;
    flex-direction: column;
    transition: transform .26s, box-shadow .26s;
  }
  .pcard:hover { transform: translateY(-6px); box-shadow: 0 18px 40px rgba(22,19,17,.10); }
  .pcard__top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .pcard__kick { font-family: var(--mono); font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; color: var(--kola); }
  .pcard__dur { font-family: var(--mono); font-size: .68rem; color: #8a8175; }
  .pcard__title { font-family: var(--display); font-weight: 800; font-size: 1.6rem; margin-bottom: 14px; letter-spacing: -.01em; }
  .pcard__body { color: #4a433b; font-size: .95rem; line-height: 1.6; flex: 1; }
  .pcard__points { list-style: none; margin-top: 22px; display: flex; flex-direction: column; gap: 11px; }
  .pcard__points li { display: flex; align-items: center; gap: 12px; font-size: .9rem; color: var(--encre); font-weight: 500; }
  .pcard__eye { width: 22px; height: 14px; flex: none; color: var(--ocre); fill: currentColor; }

  @media (max-width: 860px) { .prog-grid { grid-template-columns: 1fr; } }
</style>
